# Server Configuration
PORT=5000

# OpenAI API Key (Optional: if blank, the server runs in High-Fidelity Mock Mode)
OPENAI_API_KEY=your_openai_api_key_here

# MongoDB Connection String
MONGODB_URI=mongodb+srv://ssahoo_db_user:<password>@cluster0.ohu2ytm.mongodb.net/?appName=Cluster0

